{
  "name": "obsidian-ai-literary-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Obsidian Literary Assistant plugin monorepo.",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @obsidian-ai-literary-assistant/core-utils build && pnpm --filter @obsidian-ai-literary-assistant/obsidian-plugin build",
    "dev": "pnpm --filter @obsidian-ai-literary-assistant/obsidian-plugin dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm --filter @obsidian-ai-literary-assistant/core-utils typecheck && pnpm --filter @obsidian-ai-literary-assistant/obsidian-plugin typecheck"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@stylistic/eslint-plugin": "^2.12.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
