{
  "name": "@obsidian-ai-literary-assistant/obsidian-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs development --watch",
    "test": "tsc -p tsconfig.test.json --noEmit && esbuild src/run-tests.ts --bundle --platform=node --format=cjs --loader:.md=text --external:obsidian --outfile=dist-test/run-tests.cjs && node dist-test/run-tests.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.68",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@obsidian-ai-literary-assistant/core-utils": "workspace:*",
    "ai": "^6.0.198",
    "i18next": "^24.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "esbuild": "^0.24.2",
    "obsidian": "^1.7.2"
  }
}
